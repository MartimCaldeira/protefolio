---
---

<header>
  <nav class="container" aria-label="Navegação principal">
    <a class="marca" href="/">Martim Caldeira<span class="ouro">.</span></a>
    <ul>
      <li><a href="/#sobre">Sobre</a></li>
      <li><a href="/#projetos">Projetos</a></li>
      <li><a href="/#contacto">Contacto</a></li>
    </ul>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--borda);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 4rem;
  }

  .marca {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--texto);
    white-space: nowrap;
  }

  .marca:hover {
    color: var(--ouro);
  }

  ul {
    display: flex;
    gap: 1.75rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  ul a {
    font-family: var(--font-titulos);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--texto-suave);
  }

  ul a:hover {
    color: var(--ouro);
  }

  @media (max-width: 480px) {
    .marca {
      font-size: 0.95rem;
    }

    ul {
      gap: 1rem;
    }

    ul a {
      font-size: 0.85rem;
    }
  }
</style>
