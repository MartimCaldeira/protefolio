---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
import '../styles/global.css';

interface Props {
  titulo?: string;
  descricao?: string;
}

const {
  titulo = 'Martim Caldeira — Programador C#/.NET · Lisboa',
  descricao = 'Portfólio de Martim Caldeira: ferramentas web reais construídas com C#/.NET, ASP.NET Core MVC e Entity Framework. Finalista de TGPSI, na zona de Lisboa.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
---

<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0c0c10" />
    <meta name="author" content="Martim Caldeira" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descricao} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="pt_PT" />
    <meta property="og:site_name" content="Martim Caldeira" />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <slot />
  </body>
</html>
